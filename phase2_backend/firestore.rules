rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Vartotojų profiliai: kiekvienas mato visus (vardams), bet keičia tik savo.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   // username validuojam TIK jei jis keičiamas. Kitų laukų
                   // (avataro, nustatymų) atnaujinimas nesiunčiant username veiks.
                   && (
                     !request.resource.data.diff(resource.data).affectedKeys().hasAny(['username'])
                     || (
                       request.resource.data.username is string
                       && request.resource.data.username.size() >= 2
                       && request.resource.data.username.size() <= 16
                     )
                   );
    }

    // Globali reitingų lentelė: žaidėjai gali TIK skaityti.
    // Rašo TIK Cloud Functions (Admin SDK taisyklių neriboja).
    match /leaderboard/{scoreId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Aktyvūs žaidimai (su slaptais atsakymais): klientui VISIŠKAI uždara.
    match /active_games/{gameId} {
      allow read, write: if false;
    }
  }
}
